import tkinter as tk
from tkinter import messagebox

def est_valide(grille, num, pos):
    ligne, col = pos
    for i in range(9):
        if grille[ligne][i] == num and col != i: return False
        if grille[i][col] == num and ligne != i: return False
    
    debut_ligne, debut_col = (ligne // 3) * 3, (col // 3) * 3
    for i in range(debut_ligne, debut_ligne + 3):
        for j in range(debut_col, debut_col + 3):
            if grille[i][j] == num and (i, j) != (ligne, col):
                return False
    return True

class SudokuGUI:
    def __init__(self, racine):
        self.racine = racine
        self.racine.title("Sudoku Expert")
        
        self.grille_interne = [[0 for _ in range(9)] for _ in range(9)]
        self.taille_case = 50
        self.cote = self.taille_case * 9
        
        self.canvas = tk.Canvas(racine, width=self.cote, height=self.cote, bg="white")
        self.canvas.grid(row=0, column=0, padx=10, pady=10)
        
        self.dessiner_lignes()
        
        self.canvas.bind("<Button-1>", self.clic_souris)
        self.racine.bind("<Key>", self.appui_touche)
        
        self.selection = None

    def dessiner_lignes(self):
        for i in range(10):
            largeur = 3 if i % 3 == 0 else 1
            self.canvas.create_line(0, i * self.taille_case, self.cote, i * self.taille_case, width=largeur)
            self.canvas.create_line(i * self.taille_case, 0, i * self.taille_case, self.cote, width=largeur)

    def clic_souris(self, event):
        col = event.x // self.taille_case
        ligne = event.y // self.taille_case
        self.selection = (ligne, col)
        
        self.canvas.delete("curseur")
        x1, y1 = col * self.taille_case, ligne * self.taille_case
        self.canvas.create_rectangle(x1, y1, x1 + self.taille_case, y1 + self.taille_case, 
                                     outline="blue", width=2, tags="curseur")

    def appui_touche(self, event):
        if self.selection:
            ligne, col = self.selection
            touche = event.char
            
            if touche.isdigit() and touche != "0":
                num = int(touche)
                if est_valide(self.grille_interne, num, (ligne, col)):
                    self.grille_interne[ligne][col] = num
                else:
                    messagebox.showwarning("Erreur", "Chiffre impossible ici !")
            elif touche == "\x08" or touche == "0":
                self.grille_interne[ligne][col] = 0
            
            self.actualiser_affichage()

    def actualiser_affichage(self):
        self.canvas.delete("texte")
        for r in range(9):
            for c in range(9):
                valeur = self.grille_interne[r][c]
                if valeur != 0:
                    x = c * self.taille_case + self.taille_case // 2
                    y = r * self.taille_case + self.taille_case // 2
                    self.canvas.create_text(x, y, text=str(valeur), font=("Arial", 18), tags="texte")

if __name__ == "__main__":
    fenetre = tk.Tk()
    app = SudokuGUI(fenetre)
    fenetre.mainloop()
